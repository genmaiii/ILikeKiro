<div class="container">
  <p id="notice"><%= flash[:notice] %></p>
  <h2>投稿詳細</h2>
  <%= link_to user_path(@post.user) do %>
  <%= attachment_image_tag @post.user, :profile_image, :fill, 80, 80, fallback: "no_image.png" %>
  <% end %>
  <%= @post.user.name %>
  <p>投稿日時：<%= @post.created_at.strftime('%Y/%m/%d') %></p>
  <p>ライブ日時：<%= @post.live_date.strftime('%Y/%m/%d') %></p>
  <p>開催地：<%= @post.venue %></p>
  <p>ライブ名：<%= @post.live_name %></p>
  <p>本文：<%= @post.comment %></p>
  <%= link_to "編集する", edit_post_path(@post), class: "btn btn-sm btn-success" %>
</div>
