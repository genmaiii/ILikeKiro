<div class="container-md">
  <h2>投稿編集</h2>
  
  <% if @post.errors.any? %>
    <p>投稿を更新できませんでした</p>
    <ul>
    <% @post.errors.full_messages.each do |message| %>
      <li><%= message %></li>
    <% end %>
    </ul>
  <% end %>
  
  <%= form_with model:@post, local: true do |f| %>
    <div>
      <%= f.label :live_date, 'ライブ日時' %>
      <%= f.date_field :live_date %>
    </div>
    
    <div>
      <%= f.label :venue, '開催地' %>
      <%= f.select :venue, [["北海道", "北海道"], ["青森県", "青森県"], ["岩手県", "岩手県"], ["宮城県", "宮城県"], ["秋田県", "秋田県"], ["山形県", "山形県"], ["福島県", "福島県"], ["茨城県", "茨城県"], ["栃木県", "栃木県"], ["群馬県", "群馬県"], ["埼玉県", "埼玉県"], ["千葉県", "千葉県"], ["東京都", "東京都"], ["神奈川県", "神奈川県"], ["新潟県", "新潟県"], ["富山県", "富山県"], ["石川県", "石川県"], ["福井県", "福井県"], ["山梨県", "山梨県"], ["長野県", "長野県"], ["岐阜県", "岐阜県"], ["静岡県", "静岡県"], ["愛知県", "愛知県"], ["三重県", "三重県"], ["滋賀県", "滋賀県"], ["京都府", "京都府"], ["大阪府", "大阪府"], ["兵庫県", "兵庫県"], ["奈良県", "奈良県"], ["和歌山県", "和歌山県"], ["鳥取県", "鳥取県"], ["島根県", "島根県"], ["岡山県", "岡山県"], ["広島県", "広島県"], ["山口県", "山口県"], ["徳島県", "徳島県"], ["香川県", "香川県"], ["愛媛県", "愛媛県"], ["高知県", "高知県"], ["福岡県", "福岡県"], ["佐賀県", "佐賀県"], ["長崎県", "長崎県"], ["熊本県", "熊本県"], ["大分県", "大分県"], ["宮崎県", "宮崎県"], ["鹿児島県", "鹿児島県"], ["沖縄県", "沖縄県"], ["海外", "海外"], ["オンライン", "オンライン"]], include_blank: "選択してください" %>
    </div>
    
    <div>
      <%= f.label :category, 'カテゴリ' %>
      <%= f.select :category, [["ワンマン","ワンマン"], ["対バン", "対バン"], ["フェス", "フェス"], ["その他", "その他"]], include_blank: "選択してください" %>
    </div>
    
    <div>
      <%= f.label :live_name, 'ライブ名' %>
      <%= f.text_field :live_name, list: 'liveNames', class: 'form-control', placeholder: '入力または選択してください' %>
    </div>
    
    <div>
      <datalist id="liveNames">
        <% Live.all.each do |live| %>
          <option value="<%= live.name %>">
        <% end %>
      </datalist>
    </div>
    
    <div>
      <%= f.label :comment, '本文' %>
      <%= f.text_area :comment, class: "form-control" %>
    </div>
    
    <div class="form-group">
      <%= f.submit '変更を保存', class: "btn btn-success" %>
    </div>
  <% end %>
</div>