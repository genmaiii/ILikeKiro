<div>
  <%= form_with model: @live, local:true, class: "form-group" do |f| %>
    <div class="form-group">
      <label for="live_name">ライブ名</label>
      <%= f.text_field :name, class: "form-control" %>
    </div>
  
    <div class="form-group">
      <%= f.submit '追加する', class: "btn btn-success" %>
    </div>
  <% end %>
  
　<div>
　  <a class="text-light" href="/lives">ライブ一覧</a>
　</div>
</div>
