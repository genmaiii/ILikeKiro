<div class="container">
  <h2>新規ライブ</h2>
  
  <% if @live.errors.any? %>
    <%= @live.errors.count %>件のエラーが発生しました
    <ul>
    <% @live.errors.full_messages.each do |message| %>
      <li><%= message %></li>
    <% end %>
    </ul>
  <% end %>
  
  <%= form_with model: @live, local:true, class: "form-group" do |f| %>
    <div class="form-group">
      <label for="live_name">ライブ名</label>
      <%= f.text_field :name, class: "form-control" %>
    </div>

    <div class="form-group">
      <%= f.submit '追加する', class: "btn btn-success" %>
    </div>
  <% end %>

　<div>
　  <a class="text-light" href="/lives">ライブ一覧</a>
　</div>
</div>
